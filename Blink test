/*
 * ESP32 Blink Test
 * Target Pin: GPIO 43 (TXD0)
 */

const int ledPin = 43;

void setup() {
  // Initialize the pin as an output
  pinMode(ledPin, OUTPUT);
}

void loop() {
  digitalWrite(ledPin, HIGH); // Turn the LED on
  delay(500);                // Wait for 500ms
  digitalWrite(ledPin, LOW);  // Turn the LED off
  delay(500);                // Wait for 500ms
}
